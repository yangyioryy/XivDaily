# 应用基础配置
APP_NAME=XivDaily Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO

# 数据库配置
DATABASE_URL=sqlite:///./data/xivdaily.db

# arXiv 接口配置
ARXIV_BASE_URL=https://export.arxiv.org/api/query
ARXIV_REQUEST_TIMEOUT_SECONDS=20
ARXIV_CACHE_TTL_SECONDS=900

# 大模型网关配置
LLM_BASE_URL=https://yangyioryy.cc.cd
LLM_API_KEY=
LLM_MODEL=glm5
LLM_REQUEST_TIMEOUT_SECONDS=30
PAPER_PDF_TIMEOUT_SECONDS=20
PAPER_PDF_MAX_BYTES=15728640
PAPER_CHAT_CONTEXT_CHARS_PER_PAPER=12000

# Zotero 配置
ZOTERO_BASE_URL=https://api.zotero.org
ZOTERO_USER_ID=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_API_KEY=
ZOTERO_TARGET_COLLECTION_NAME=XivDaily
